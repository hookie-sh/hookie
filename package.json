{
  "name": "hookie",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "infra:up": "docker compose up -d && supabase start",
    "infra:down": "docker compose down && supabase stop",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.6.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "supabase": "^2.54.11"
  }
}
